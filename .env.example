# Google login
# ใช้ OAuth 2.0 Client ID ประเภท Web application จาก Google Cloud Console
# Authorized JavaScript origins ที่ต้องใส่อย่างน้อย:
# - http://localhost:3000
# - https://www.aixclub.co
GOOGLE_CLIENT_ID=

# Authentication/session
AUTH_SECRET=
AUTH_SESSION_TTL_MS=604800000

# Supabase Postgres
# ใช้ connection string จาก Supabase Dashboard > Connect > Session pooler หรือ Transaction pooler
# บน Render ห้ามใช้ Direct connection ถ้าเจอ IPv6/ENETUNREACH; ให้ใช้ pooler URL แทน
# Server จะอ่านตามลำดับ: SUPABASE_DATABASE_URL, DATABASE_URL, SUPABASE_DB_URL
SUPABASE_DATABASE_URL=
SUPABASE_DB_SSL=true
SUPABASE_DB_POOL_MAX=4
SUPABASE_QUERY_TIMEOUT_MS=30000
SUPABASE_AUTO_MIGRATE=false

# Stripe payment
# ใช้ Secret key จาก Stripe Dashboard หรือ Stripe CLI test key
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: ถ้ามี Price ใน Stripe แล้ว ใส่ price_xxx; ถ้าไม่ใส่ ระบบจะสร้าง price_data 1,999 THB ตอน checkout
STRIPE_PRICE_ID=
STRIPE_PAYMENT_METHOD_TYPES=card,promptpay
STRIPE_API_VERSION=
# เปิดเฉพาะ dev ถ้าต้องการปุ่ม mock confirm เดิม
ALLOW_DEV_PAYMENT_CONFIRM=false

# SMS จริงสำหรับเบอร์ไทย: ใช้ ThaibulkSMS
# สร้าง API Key / API Secret จาก https://developer.thaibulksms.com/
THAIBULKSMS_API_KEY=
THAIBULKSMS_API_SECRET=
THAIBULKSMS_SENDER=Demo

# หรือใช้ Twilio แทน ThaibulkSMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OTP settings
SMS_OTP_TTL_MS=300000
SMS_OTP_RESEND_MS=60000
SMS_OTP_MAX_ATTEMPTS=5

# AiX Teacher Terminal
# ใช้ OpenAI Responses API สำหรับอาจารย์ AI ในหน้าเรียน
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
