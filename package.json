{
  "name": "aix-website",
  "version": "1.0.1",
  "description": "",
  "main": "server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node server.js",
    "cf:prepare": "mkdir -p cloudflare/assets && rsync -a --delete --delete-excluded --exclude '.git' --exclude '.gitignore' --exclude '.playwright-cli' --exclude '.DS_Store' --exclude '.assetsignore' --exclude 'cloudflare' --exclude 'node_modules' --exclude 'old aix-club' --exclude 'outputs' --exclude 'output/playwright' --exclude 'tests' --exclude 'videos' --exclude 'data.db*' --exclude 'uploads' --exclude 'server.js' --exclude 'postgres-worker.js' --exclude 'supabase' --exclude 'rewrite_admin.js' --exclude 'package.json' --exclude 'package-lock.json' --exclude 'wrangler.jsonc' --exclude '.env*' ./ cloudflare/assets/",
    "cf:dev": "wrangler dev",
    "cf:check": "npm run cf:prepare && wrangler deploy --dry-run --env=\"\"",
    "cf:deploy:dry-run": "npm run cf:check",
    "cf:deploy": "npm run cf:prepare && wrangler deploy --env=\"\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pg": "^8.22.0",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "acorn": "8.15.0",
    "wrangler": "^4.95.0"
  }
}
